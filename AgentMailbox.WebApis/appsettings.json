{
  "Storage": {
    "DatabasePath": "app_data/agentmailbox.db",
    "RawMailRootPath": "app_data/raw-mails",
    "AttachmentRootPath": "app_data/attachments"
  },
  "InboundListener": {
    "Enabled": false,
    "Host": "127.0.0.1",
    "Port": 2525
  },
  "OutboundSmtp": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 25,
    "Username": null,
    "Password": null,
    "FromDomain": "local.ai",
    "UseSsl": false
  },
  "Retry": {
    "MaxAttempts": 3,
    "InitialDelaySeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
